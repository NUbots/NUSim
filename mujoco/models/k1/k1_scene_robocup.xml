  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.35 0.55 0.75" rgb2="0 0 0" width="512" height="512"/>
    <texture name="grass_tex" type="2d" builtin="checker" rgb1="0.06 0.35 0.08" rgb2="0.05 0.30 0.07"
              width="300" height="300" mark="edge" markrgb="0.08 0.4 0.1"/>
    <material name="grass_mat" texture="grass_tex" texrepeat="22 16" texuniform="true" reflectance="0.05" specular="0.1"/>
    <material name="post_mat" rgba="0.95 0.95 0.95 1"/>
    <material name="ball_mat" rgba="0.85 0.25 0.05 1"/>
  </asset>

  <visual>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.5 0.5 0.5" specular="0.2 0.2 0.2"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <worldbody>
    <light name="sun1" directional="true" pos="3 2 6" dir="-0.4 -0.3 -1" diffuse="0.7 0.7 0.65" specular="0.2 0.2 0.2" castshadow="true"/>
    <light name="sun2" directional="true" pos="-3 -2 6" dir="0.3 0.2 -1" diffuse="0.35 0.35 0.35" specular="0.05 0.05 0.05" castshadow="false"/>

    <!-- Pitch: half-size 5.5 x 4.0 m (11 x 8 m total = 9x6 field + 1m border), matching the Webots proto's grass extent. -->
    <geom name="floor" type="plane" pos="0 0 0" size="5.5 4.0 0.1" material="grass_mat" condim="3" friction="0.8 0.02 0.001"/>

